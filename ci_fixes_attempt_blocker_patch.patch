diff --git a/tools/build/Invoke-LLMBuild.ps1 b/tools/build/Invoke-LLMBuild.ps1
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/tools/build/Invoke-LLMBuild.ps1
@@ -0,0 +1,159 @@
+#requires -Version 5.1
+[CmdletBinding()]
+param(
+    [switch]$Lint,
+    [switch]$Test,
+    [switch]$Docs,
+    [switch]$WhatIf,
+    [switch]$CI,
+    [string]$ProjectRoot = ""
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = "Stop"
+
+if ([string]::IsNullOrWhiteSpace($ProjectRoot)) {
+    $ProjectRoot = (Resolve-Path -LiteralPath (Join-Path $PSScriptRoot "..\..")).Path
+}
+else {
+    $ProjectRoot = (Resolve-Path -LiteralPath $ProjectRoot).Path
+}
+
+function Invoke-RepoScript {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory = $true)]
+        [string]$RelativePath,
+
+        [Parameter()]
+        [hashtable]$Arguments = @{}
+    )
+
+    $scriptPath = Join-Path $ProjectRoot $RelativePath
+    if (-not (Test-Path -LiteralPath $scriptPath)) {
+        throw "Required build script not found: $RelativePath"
+    }
+
+    & $scriptPath @Arguments
+}
+
+function Invoke-LLMBuildLint {
+    [CmdletBinding()]
+    param()
+
+    $moduleRoot = Join-Path $ProjectRoot "module\LLMWorkflow"
+    if (-not (Test-Path -LiteralPath $moduleRoot)) {
+        throw "Module root not found: $moduleRoot"
+    }
+
+    $pssa = Get-Module -ListAvailable PSScriptAnalyzer |
+        Sort-Object Version -Descending |
+        Select-Object -First 1
+
+    if (-not $pssa) {
+        throw "PSScriptAnalyzer is not installed. Run: Install-Module PSScriptAnalyzer -Scope CurrentUser -Force"
+    }
+
+    Import-Module $pssa.Path -Force
+
+    $ruleRoot = Join-Path $ProjectRoot "tools\build\PSScriptAnalyzer"
+    $rules = @()
+    if (Test-Path -LiteralPath $ruleRoot) {
+        $rules = @(Get-ChildItem -Path $ruleRoot -Filter "*.psm1" -File)
+    }
+
+    $analyzerParams = @{
+        Path        = $moduleRoot
+        Recurse     = $true
+        Severity    = @("Error", "Warning")
+        ExcludeRule = @("PSUseSingularNouns")
+    }
+
+    if ($rules.Count -gt 0) {
+        $analyzerParams["CustomRulePath"] = @($rules.FullName)
+    }
+
+    $results = @(Invoke-ScriptAnalyzer @analyzerParams)
+    $errors = @($results | Where-Object { $_.Severity -eq "Error" })
+    $warnings = @($results | Where-Object { $_.Severity -eq "Warning" })
+
+    if ($warnings.Count -gt 0) {
+        Write-Output "::warning::PSScriptAnalyzer warnings found:"
+        $warnings | Format-Table -AutoSize | Out-String | Write-Output
+    }
+
+    if ($errors.Count -gt 0) {
+        Write-Output "::error::PSScriptAnalyzer errors found:"
+        $errors | Format-Table -AutoSize | Out-String | Write-Output
+        throw "PSScriptAnalyzer found $($errors.Count) error(s)."
+    }
+
+    Write-Output "PSScriptAnalyzer linting complete. No errors found."
+}
+
+function Invoke-LLMBuildTests {
+    [CmdletBinding()]
+    param()
+
+    $args = @{
+        Path = @(Join-Path $ProjectRoot "tests")
+        CI   = $CI
+    }
+
+    Invoke-RepoScript -RelativePath "tools\ci\invoke-pester-safe.ps1" -Arguments $args
+}
+
+function Invoke-LLMBuildDocs {
+    [CmdletBinding()]
+    param()
+
+    Invoke-RepoScript -RelativePath "tools\ci\validate-docs-truth.ps1"
+
+    $releaseDocs = @(
+        "README.md",
+        "PROGRESS.md",
+        "docs\implementation\PROGRESS.md",
+        "docs\implementation\REMAINING_WORK.md",
+        "docs\releases\RELEASE_STATE.md",
+        "docs\releases\V1_RELEASE_CRITERIA.md",
+        "docs\releases\RELEASE_CERTIFICATION_CHECKLIST.md",
+        "docs\reference\DOCS_TRUTH_MATRIX.md"
+    )
+
+    $mojibakePattern = "Â|â€™|â€œ|â€�|â€“|â€”|âœ|ðŸ"
+    $badFiles = New-Object System.Collections.Generic.List[string]
+
+    foreach ($relativePath in $releaseDocs) {
+        $path = Join-Path $ProjectRoot $relativePath
+        if (-not (Test-Path -LiteralPath $path)) {
+            continue
+        }
+
+        $content = Get-Content -LiteralPath $path -Raw
+        if ($content -match $mojibakePattern) {
+            $badFiles.Add($relativePath)
+        }
+    }
+
+    if ($badFiles.Count -gt 0) {
+        throw "Release-facing documentation contains mojibake/encoding corruption: $($badFiles -join ', ')"
+    }
+}
+
+function Invoke-LLMBuildChecks {
+    [CmdletBinding()]
+    param()
+
+    Invoke-RepoScript -RelativePath "tools\ci\check-template-drift.ps1"
+    Invoke-RepoScript -RelativePath "tools\ci\validate-compatibility-lock.ps1"
+    Invoke-RepoScript -RelativePath "tools\ci\validate-docs-truth.ps1"
+
+    foreach ($probe in @("_content_probe.txt", "f")) {
+        $probePath = Join-Path $ProjectRoot $probe
+        if (Test-Path -LiteralPath $probePath) {
+            throw "Release-blocking scratch/stale artifact is checked in: $probe"
+        }
+    }
+}
+
+$explicitTask = $Lint -or $Test -or $Docs -or $WhatIf
+
+if (-not $explicitTask) {
+    Invoke-LLMBuildLint
+    Invoke-LLMBuildChecks
+    Invoke-LLMBuildTests
+    Invoke-LLMBuildDocs
+    return
+}
+
+if ($Lint) { Invoke-LLMBuildLint }
+if ($WhatIf) { Invoke-LLMBuildChecks }
+if ($Test) { Invoke-LLMBuildTests }
+if ($Docs) { Invoke-LLMBuildDocs }
