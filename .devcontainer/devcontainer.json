{
  "name": "Repo Cortex Dev Container",
  "image": "mcr.microsoft.com/powershell:lts-7.4-ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "pwsh -Command 'Install-Module Pester -Scope CurrentUser -Force -SkipPublisherCheck -MinimumVersion 5.5.0; Install-Module PSScriptAnalyzer -Scope CurrentUser -Force' && pip install chromadb",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.powershell",
        "ms-python.python",
        "editorconfig.editorconfig",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "powershell.codeFormatting.preset": "OTBS",
        "powershell.scriptAnalysis.enable": true,
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [8000, 8075, 11434],
  "portsAttributes": {
    "8000": { "label": "ChromaDB" },
    "8075": { "label": "ContextLattice Orchestrator" },
    "11434": { "label": "Ollama" }
  },
  "remoteUser": "root"
}
