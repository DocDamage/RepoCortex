# LLM Workflow Toolkit - Environment Configuration Example
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control!

# =============================================================================
# LLM Provider API Keys
# Configure at least one provider for code analysis
# =============================================================================

# OpenAI (recommended for general use)
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude (alternative with larger context window)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Moonshot Kimi (Chinese/English bilingual)
# KIMI_API_KEY=sk-your-kimi-key-here

# Google Gemini (multimodal capabilities)
# GEMINI_API_KEY=your-gemini-key-here

# Zhipu GLM (Chinese optimized)
# GLM_API_KEY=your-glm-key-here

# Ollama (local inference, optional key)
# OLLAMA_API_KEY=optional

# =============================================================================
# Provider Base URLs (optional - only if using custom endpoints)
# =============================================================================

# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# ContextLattice Configuration
# Required for MemPalace bridge and remote memory storage
# =============================================================================

# ContextLattice orchestrator endpoint
# Required: docker-compose.yml does not define a bundled ContextLattice service.
# Set this to a reachable external orchestrator URL.
# Local shell example:
# CONTEXTLATTICE_ORCHESTRATOR_URL=http://localhost:8075
# Docker Compose example:
# CONTEXTLATTICE_ORCHESTRATOR_URL=http://host.docker.internal:8075

# ContextLattice API key (required for write operations)
# CONTEXTLATTICE_ORCHESTRATOR_API_KEY=your-api-key-here

# =============================================================================
# MemPalace Configuration
# Local ChromaDB vector store settings
# =============================================================================

# Path to ChromaDB persistent storage
# Default: ~/.mempalace/palace (Linux/Mac) or C:\Users\<user>\.mempalace\palace (Windows)
# MEMPALACE_PALACE_PATH=/path/to/your/palace

# Collection name for this project's memories
# MEMPALACE_COLLECTION_NAME=mempalace_drawers

# =============================================================================
# LLM Workflow Settings
# =============================================================================

# Default provider preference (auto-detects if not set)
# LLM_PROVIDER=openai

# Logging level: DEBUG, INFO, WARN, ERROR
# LLM_WORKFLOW_LOG_LEVEL=INFO

# Development mode (enables additional debugging)
# LLM_WORKFLOW_DEV_MODE=false

# =============================================================================
# Docker-specific Settings
# These are used when running in Docker containers
# =============================================================================

# ChromaDB service port mapping (host:container)
# CHROMADB_PORT=8000

# ContextLattice service port mapping
# CONTEXTLATTICE_PORT=8075

# Ollama service port mapping
# OLLAMA_PORT=11434

# Custom tools path (mounted into container)
# CUSTOM_TOOLS_PATH=/path/to/custom/tools

# ContextLattice Docker image (override for custom orchestrator)
# CONTEXTLATTICE_IMAGE=your-registry/contextlattice:latest
